<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup> 
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  
  <connectionStrings>
    <!-- Schimbă SERVER și path-ul după cum este necesar -->
    <add name="BibliotecaDB" 
         connectionString="Server=localhost\SQLEXPRESS;Database=BibliotecaScolara;Trusted_Connection=true;" 
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <!-- Configurări generale -->
    <add key="ApplicationName" value="Biblioteca Școlară" />
    <add key="ApplicationVersion" value="1.0.0" />
    
    <!-- Zile pentru împrumut (default 30) -->
    <add key="ZileImprumutDefault" value="30" />
    
    <!-- Setări display -->
    <add key="GridPageSize" value="20" />
    <add key="MaxSearchResults" value="500" />
    
    <!-- Setări de log -->
    <add key="EnableLogging" value="true" />
    <add key="LogPath" value="Logs\" />
  </appSettings>

  <system.net>
    <mailSettings>
      <!-- Dacă se vor implementa notificări prin email -->
      <smtp from="biblioteca@scoala.ro">
        <network host="smtp.gmail.com" port="587" userName="your-email@gmail.com" password="your-password" />
      </smtp>
    </mailSettings>
  </system.net>
</configuration>
